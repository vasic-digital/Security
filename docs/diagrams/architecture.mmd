            CChain --> CFilter
            CChain --> CResult
            CLength -.->|implements| CFilter
            CPattern -.->|implements| CFilter
            CKeyword -.->|implements| CFilter
        end

        subgraph "pkg/policy"
            PEEnforcer["Enforcer"]
            PEPolicy["Policy"]
            PERule["Rule"]
            PECondition["Condition"]
            PEContext["EvaluationContext"]
            PEResult["EvaluationResult"]
            PEDecision["Decision"]
