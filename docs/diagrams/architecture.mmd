graph TD
    subgraph "digital.vasic.security"
        subgraph "pkg/guardrails"
            GEngine["Engine"]
            GRule["&laquo;interface&raquo;<br/>Rule"]
            GConfig["Config"]
            GRuleConfig["RuleConfig"]
            GResult["Result"]
            GRuleResult["RuleResult"]
            GSeverity["Severity"]
            GMaxLength["MaxLengthRule"]
            GForbidden["ForbiddenPatternsRule"]
            GRequire["RequireFormatRule"]

            GEngine --> GRule
            GEngine --> GConfig
            GEngine --> GResult
            GConfig --> GRuleConfig
            GRuleConfig --> GSeverity
            GResult --> GRuleResult
            GRuleResult --> GSeverity
            GMaxLength -.->|implements| GRule
            GForbidden -.->|implements| GRule
            GRequire -.->|implements| GRule
        end

        subgraph "pkg/pii"
            PRedactor["Redactor"]
            PDetector["&laquo;interface&raquo;<br/>Detector"]
