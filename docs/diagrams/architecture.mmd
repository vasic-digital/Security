            PRedactor --> PMatch
            PConfig --> PType
            PConfig --> PStrategy
            PMatch --> PType
            PEmail -.->|implements| PDetector
            PPhone -.->|implements| PDetector
            PSSN -.->|implements| PDetector
            PCard -.->|implements| PDetector
            PIP -.->|implements| PDetector
        end

        subgraph "pkg/content"
            CChain["ChainFilter"]
            CFilter["&laquo;interface&raquo;<br/>Filter"]
            CResult["FilterResult"]
